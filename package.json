{
  "private": true,
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.32.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^17.0.0",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vite-plugin-ruby": "^5.1.1",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@inertiajs/vue3": "^2.0.17",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "<2.0",
    "reka-ui": "^2.8.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.8.3",
    "vue": "^3.5.18",
    "vue-i18n": "^11.2.8",
    "vue-sonner": "^2.0.8",
    "vue-tsc": "^3.0.4"
  },
  "scripts": {
    "check": "vue-tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "eslint '*.{js,mjs,cjs,ts}' app/frontend --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "bun run lint -- --fix",
    "format": "prettier --check 'app/frontend' '*.{js,mjs,cjs,ts}'",
    "format:fix": "bun run format -- --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
